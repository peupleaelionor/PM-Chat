# Dependencies
node_modules/
.npm

# Workspace-level lock files (root package-lock.json is authoritative)
apps/*/package-lock.json
packages/*/package-lock.json

# Next.js
.next/
out/
next-env.d.ts

# TypeScript
*.tsbuildinfo

# Environment — NEVER commit secrets
.env
.env.local
.env.production
.env.*.local

# Build
dist/
build/

# Uploads (may contain encrypted attachments)
apps/server/uploads/

# Logs — may contain sensitive metadata
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# OS
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# Testing
coverage/
.jest-cache/

# Docker
.dockerignore

# IDE
.vscode/
.idea/
*.code-workspace

# Temp files
tmp/
temp/
