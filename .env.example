# Serveur
NODE_ENV=development
PORT=4000
JWT_SECRET=votre-secret-jwt-a-changer-en-production
JWT_REFRESH_SECRET=votre-secret-refresh-a-changer-en-production

# Base de données
MONGODB_URI=mongodb://localhost:27017/pmchat
REDIS_URL=redis://localhost:6379

# CORS (liste séparée par virgules)
CORS_ORIGINS=http://localhost:3000

# Envoi de fichiers
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# Web (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000
