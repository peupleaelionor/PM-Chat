{
  "version": 2,
  "installCommand": "npm install",
  "builds": [
    { "src": "api/index.ts", "use": "@vercel/node" },
    { "src": "api/cron.ts",  "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/cron", "dest": "/api/cron.ts" },
    { "src": "/(.*)",     "dest": "/api/index.ts" }
  ],
  "crons": [
    { "path": "/api/cron", "schedule": "* * * * *" }
  ],
  "env": {
    "NODE_ENV": "production",
    "MONGODB_URI": "@pm-chat-mongodb-uri",
    "REDIS_URL": "@pm-chat-redis-url",
    "JWT_SECRET": "@pm-chat-jwt-secret",
    "JWT_REFRESH_SECRET": "@pm-chat-jwt-refresh-secret",
    "CORS_ORIGINS": "@pm-chat-cors-origins"
  }
}
