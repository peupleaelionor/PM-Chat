# Configuration du serveur
NODE_ENV=development
PORT=4000
HOST=0.0.0.0

# MongoDB
MONGODB_URI=mongodb://localhost:27017/pm-chat

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=changez-moi-pour-un-long-secret-aleatoire-en-production
JWT_REFRESH_SECRET=changez-moi-pour-un-secret-refresh-en-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS (liste séparée par virgules)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Envoi de fichiers
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# Limitation de débit
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Expiration des messages
MESSAGE_EXPIRY_JOB_INTERVAL_MS=60000

# Arrêt progressif
SHUTDOWN_TIMEOUT_MS=10000
